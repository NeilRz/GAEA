# GEOM environment template — copy to .env.local and fill in.

# Oracle signer (Ed25519 Solana secret key, base58 or solana-keygen JSON array).
# Without it the app falls back to a publicly derivable dev key.
ORACLE_SIGNER_KEY=

# Solana anchoring (scripts/anchor.ts)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Map satellite basemap. Default is NASA GIBS Blue Marble (public domain,
# no key, native max zoom 8). To use a licensed provider (Esri, MapTiler,
# Mapbox…), set the tile URL template, its attribution, and its limits.
NEXT_PUBLIC_SATELLITE_TILE_URL=
NEXT_PUBLIC_SATELLITE_ATTRIBUTION=
NEXT_PUBLIC_SATELLITE_TILE_SIZE=256
NEXT_PUBLIC_SATELLITE_MAX_ZOOM=8
